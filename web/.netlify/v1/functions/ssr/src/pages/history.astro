---
import Layout from '../layouts/Layout.astro';
import HistoryCharts from '../components/HistoryCharts';
---

<Layout title="History">
  <section class="page-header">
    <h1>History</h1>
    <p class="subtitle">Energy data over time — charts, trends, and statistics.</p>
  </section>

  <div class="page-body">
    <HistoryCharts client:load />
  </div>
</Layout>


<style>
  .page-header { margin-bottom: 0; }
  .page-header h1 { font-size: 1.75rem; font-weight: 700; color: var(--neon-pink); margin: 0 0 0.3rem; }
  .page-header .subtitle { color: var(--text-muted); margin: 0; font-size: 0.9rem; }
</style>
