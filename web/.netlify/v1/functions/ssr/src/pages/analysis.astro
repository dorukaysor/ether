---
import Layout from '../layouts/Layout.astro';
import AIAnalysis from '../components/AIAnalysis';
---

<Layout title="AI Analysis">
  <section class="page-header">
    <h1>AI Analysis</h1>
    <p class="subtitle">Deep energy insights powered by Gemini 1.5 Flash.</p>
  </section>

  <div class="page-body">
    <AIAnalysis client:load />
  </div>
</Layout>


<style>
  .page-header { margin-bottom: 0; }
  .page-header h1 { font-size: 1.75rem; font-weight: 700; color: var(--neon-yellow); margin: 0 0 0.3rem; }
  .page-header .subtitle { color: var(--text-muted); margin: 0; font-size: 0.9rem; }
</style>
