# Turso (libSQL) database
TURSO_DB_URL=libsql://your-db-name-your-org.turso.io
TURSO_DB_TOKEN=your-turso-auth-token

# Shared secret between the ESP32 (Avatar) and this backend
API_SECRET=change-me-to-a-strong-random-string

# Gemini AI (leave blank to use mock mode)
GEMINI_API_KEY=

# Telegram bot for alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CORS — comma-separated list of allowed frontend origins
# In production: your Netlify URL, e.g. https://ether-dashboard.netlify.app
CORS_ORIGIN=http://localhost:4321

# Port (Render sets this automatically)
PORT=3001
